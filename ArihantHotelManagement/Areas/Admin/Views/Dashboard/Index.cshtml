@model AdminDashboardViewModel

<h1>Admin Workflow Dashboard</h1>
<div class="stats-grid">
    <div class="glass stat"><h3>Total Rooms</h3><p>@Model.TotalRooms</p></div>
    <div class="glass stat"><h3>Total Bookings</h3><p>@Model.TotalBookings</p></div>
    <div class="glass stat"><h3>Pending</h3><p>@Model.PendingBookings</p></div>
    <div class="glass stat"><h3>Revenue (Paid)</h3><p>$@Model.Revenue</p></div>
</div>

<h2>Recent Bookings</h2>
<table class="glass table">
    <thead><tr><th>Guest</th><th>Dates</th><th>Status</th><th>Payment</th></tr></thead>
    <tbody>
    @foreach (var booking in Model.RecentBookings)
    {
        <tr>
            <td>@booking.GuestName</td>
            <td>@booking.CheckInDate.ToShortDateString() - @booking.CheckOutDate.ToShortDateString()</td>
            <td>@booking.BookingStatus</td>
            <td>@booking.PaymentStatus</td>
        </tr>
    }
    </tbody>
</table>
