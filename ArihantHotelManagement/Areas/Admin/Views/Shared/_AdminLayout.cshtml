<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ARIHANT Admin Panel</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="admin-bg">
    <div class="admin-shell">
        <aside class="admin-sidebar glass">
            <h2>ARIHANT Admin</h2>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            <a asp-area="Admin" asp-controller="Rooms" asp-action="Index">Room Control</a>
            <a asp-area="Admin" asp-controller="Bookings" asp-action="Index">Booking Workflow</a>
            <a asp-controller="Home" asp-action="Index">Back to Site</a>
        </aside>
        <section class="admin-content">
            @RenderBody()
        </section>
    </div>
</body>
</html>
